#include <iostream>
#include <cstring>
using namespace std;

int main() {
    setlocale(0, "Russian");
    char str[100];
    cout << "Введите что-то: ";
    cin.getline(str, 100);

    char* ptr = str;

    for (int i = 0; i < strlen(str); i++) {
        if (*(ptr + i) >= 'a' && *(ptr + i) <= 'z') {
            if (*(ptr + i) == 'z')
                *(ptr + i) = 'a';
            else
                *(ptr + i) += 1;
        }
        else if (*(ptr + i) >= 'A' && *(ptr + i) <= 'Z') {
            if (*(ptr + i) == 'Z')
                *(ptr + i) = 'A';
            else
                *(ptr + i) += 1;
        }
    }

    cout << "Результат: " << str << endl;
    return 0;
}
