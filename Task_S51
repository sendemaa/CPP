#include <iostream>
#include <string>
using namespace std;

void reverse(const string& str) {
    for (int i = str.size() - 1; i >= 0; --i){
        cout << str[i];}
}
int main()
{
    setlocale(0,"Russian");
    string t ="Testing";
    cout <<"Строка: "<<t<<endl;
    cout <<"Отраженная строка: ";
    reverse(t);
    cout <<endl;
    return 0;
}
