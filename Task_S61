#include <iostream>
using namespace std;

class Bucket
{
public:
    int volume; //объем в литрах
    int used;//сколько литров уже налито

    Bucket(int vol, int usd)
    {
        volume = vol;
        used = usd;
    }

    void flush()//опустошить
    {
        used = 0;
    }

    int fill(int v)//наполнить v литрами жидкости
    {
        int free_space = volume - used;
        if (v <= free_space)
        {
            used += v;
            return 0;
        }
        else 
        {
            used = volume; 
            return v - free_space; 
        }
    }
};

int main()
{
    Bucket test_01(12, 3);
    cout << "1) " << test_01.volume << ", " << test_01.used << "\n";
    int rest = test_01.fill(14);
    cout << "2) " << test_01.used << ", " << rest << "\n";

    test_01.flush();
    rest = test_01.fill(8);
    cout << "3) " << test_01.used << ", " << rest << "\n";

    return 0;
}
